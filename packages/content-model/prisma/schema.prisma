// This is the Kupuri OMA Prisma schema.
// Primary DB: PostgreSQL
// Locale: es-MX / en bilingual content

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  avatarUrl        String?
  role             UserRole  @default(CREATOR)
  locale           String    @default("es-MX")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  projects         Project[]
  teamMemberships  TeamMember[]
  communityPosts   CommunityPost[]
  buildRuns        BuildRun[]
  subscription     Subscription?
}

enum UserRole {
  VISITOR
  CREATOR
  PREMIUM
  TEAM_ADMIN
  SYSTEM_ADMIN
  AGENT_OPERATOR
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?  @db.Text
  accessToken       String?  @db.Text
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?  @db.Text
  sessionState      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Teams & Workspaces ──────────────────────────────────────────────────────

model Team {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  planTier  PlanTier     @default(FREE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  members   TeamMember[]
  projects  Project[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Subscriptions & Billing ─────────────────────────────────────────────────

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  tier              PlanTier
  currency          String    @default("MXN")
  status            SubStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  stripeCustomerId   String?
  stripeSubId        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PlanTier {
  FREE
  PRO
  STUDIO
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  description     String?       @db.Text
  defaultLocale   String        @default("es-MX")
  status          ProjectStatus @default(DRAFT)
  authorId        String
  teamId          String?
  templateId      String?
  parentProjectId String?       // remix lineage
  remixCount      Int           @default(0)
  qualityScore    Float?
  premiumOnly     Boolean       @default(false)
  screenshots     String[]
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  author          User          @relation(fields: [authorId], references: [id])
  team            Team?         @relation(fields: [teamId], references: [id])
  template        Template?     @relation(fields: [templateId], references: [id])
  parentProject   Project?      @relation("RemixLineage", fields: [parentProjectId], references: [id])
  childProjects   Project[]     @relation("RemixLineage")
  translations    ProjectTranslation[]
  assets          Asset[]
  communityPost   CommunityPost?
  buildRuns       BuildRun[]
}

enum ProjectStatus {
  DRAFT
  PREVIEW
  PUBLISHED
  ARCHIVED
}

model ProjectTranslation {
  id          String  @id @default(cuid())
  projectId   String
  locale      String
  title       String
  description String? @db.Text
  slug        String?

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
}

// ─── Templates ───────────────────────────────────────────────────────────────

model Template {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  industry      String?
  vibe          String[]
  motionFamily  String[]
  locales       String[]
  premium       Boolean  @default(false)
  threeD        Boolean  @default(false) @map("three_d")
  sectionSchema Json
  tokenPackId   String?
  heroType      String?
  sourceRepoRef String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects  Project[]
  translations TemplateTranslation[]
}

model TemplateTranslation {
  id          String   @id @default(cuid())
  templateId  String
  locale      String
  name        String
  description String?  @db.Text

  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, locale])
}

// ─── Community ───────────────────────────────────────────────────────────────

model CommunityPost {
  id               String            @id @default(cuid())
  projectId        String            @unique
  authorId         String
  summary          String?           @db.Text
  locale           String            @default("es-MX")
  tags             String[]
  featured         Boolean           @default(false)
  importedFrom     String?
  moderationState  ModerationState   @default(PENDING)
  publishedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])
  translations CommunityPostTranslation[]
}

enum ModerationState {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model CommunityPostTranslation {
  id          String        @id @default(cuid())
  postId      String
  locale      String
  summary     String?       @db.Text

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
}

// ─── Assets ─────────────────────────────────────────────────────────────────

model Asset {
  id          String    @id @default(cuid())
  projectId   String?
  filename    String
  mimeType    String
  url         String
  size        Int
  assetType   AssetType @default(IMAGE)
  createdAt   DateTime  @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

enum AssetType {
  IMAGE
  VIDEO
  MODEL_3D
  AUDIO
  DOCUMENT
  THUMBNAIL
}

// ─── Build Runs ──────────────────────────────────────────────────────────────

model BuildRun {
  id               String        @id @default(cuid())
  projectId        String?
  authorId         String
  prompt           String?       @db.Text
  graphQuery       String?       @db.Text
  outputPreviewUrl String?
  logs             Json?
  score            Float?
  status           BuildStatus   @default(PENDING)
  costCents        Int?
  runtimeMs        Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  author   User     @relation(fields: [authorId], references: [id])
  tasks    AgentTask[]
}

enum BuildStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

// ─── Agent Tasks ─────────────────────────────────────────────────────────────

model AgentTask {
  id            String     @id @default(cuid())
  runId         String
  type          String
  ownerAgent    String
  status        TaskStatus @default(PENDING)
  dependencies  String[]
  touchedFiles  String[]
  validations   Json?
  costCeiling   Int?
  result        Json?
  errorMessage  String?    @db.Text
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime   @default(now())

  run BuildRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

enum TaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
  BLOCKED
}
